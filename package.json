{
  "name": "famvault-desktop-helper",
  "version": "1.0.0-alpha.2",
  "description": "GeneGraph Import Helper — Electron app that brings Google Takeout archives and other large photo collections into GeneGraph.",
  "main": "dist/main.js",
  "author": "GeneGraph",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"tsc -w\" \"electron dist/main.js\"",
    "build": "tsc",
    "package": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:all": "npm run build && electron-builder --mac --win"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chokidar": "^3.5.3",
    "keytar": "^7.9.0",
    "yauzl": "^2.10.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^20.0.0",
    "@types/yauzl": "^2.9.2",
    "concurrently": "^8.0.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.genegraph.famvault.desktop-helper",
    "productName": "GeneGraph Import Helper",
    "files": [
      "dist/**/*.js",
      "dist/**/*.js.map",
      "assets/**/*",
      "!dist/mac-arm64",
      "!dist/*.dmg",
      "!dist/*.zip",
      "!dist/*.blockmap",
      "!dist/*.yml"
    ],
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] },
        { "target": "zip", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "afterSign": "build/notarize.js",
    "dmg": {
      "title": "GeneGraph Import Helper ${version}"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": true,
      "shortcutName": "GeneGraph Import Helper"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
